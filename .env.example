# 複製成 .env 並填入(留空的功能會自動跳過)。切勿 commit .env。

# --- AI 摘要(選用)---
# 引擎二選一:anthropic(Claude API)或 ollama(本機模型,例如 Kimi)
SUMMARY_PROVIDER=
# provider=anthropic 時需要:
ANTHROPIC_API_KEY=
# provider=ollama 時使用:
# - 雲端版(Ollama Cloud):填 OLLAMA_API_KEY(到 ollama.com → 帳號設定 → API Keys 取得),
#   位址會自動用 https://ollama.com
# - 本機版:三個都可留空(預設連 http://localhost:11434)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_MODEL=kimi-k2

# --- Reddit(選用):不填則用公開 JSON API;填了改用官方 OAuth,較穩定 ---
# 到 https://www.reddit.com/prefs/apps 建立一個 "script" 類型的 app
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Threads(平台開啟時需要)---
# 需要具備 threads_keyword_search 權限的長效 access token
THREADS_ACCESS_TOKEN=

# --- Facebook(平台開啟時需要)---
# 具備 pages_read_engagement 的粉專 access token(僅能讀你管理的粉專)
FACEBOOK_ACCESS_TOKEN=

# --- Email 摘要(email.enabled=true 時需要)---
# Gmail 建議用「應用程式密碼」(App Password),不要用登入密碼
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
